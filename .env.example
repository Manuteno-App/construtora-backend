# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (RDS PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://construtora:SENHA@<RDS_ENDPOINT>:5432/construtora

# ── Cache (ElastiCache Redis) ────────────────────────────────────────────────
REDIS_URL=redis://<REDIS_ENDPOINT>:6379

# ── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket for document storage
AWS_S3_BUCKET=construtora-documentos

# Textract (defaults to us-east-1 if omitted)
AWS_TEXTRACT_REGION=us-east-1
AWS_TEXTRACT_BUCKET=construtora-textract

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Models (optional — defaults shown) ───────────────────────────────────────
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=20

# ── RAG (optional — defaults shown) ──────────────────────────────────────────
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.35
