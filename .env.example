# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://construtora:construtora_pass@localhost:5432/construtora_db

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=construtora-atestados

# OpenAI
OPENAI_API_KEY=sk-...

# Textract staging bucket — must be in the same region as Textract (us-east-1)
# Create: aws s3 mb s3://YOUR-BUCKET-NAME --region us-east-1
AWS_TEXTRACT_REGION=us-east-1
AWS_TEXTRACT_BUCKET=your-textract-staging-bucket

# Embedding Config
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=20

# RAG Config
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.35
